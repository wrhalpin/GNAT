# GNAT Docker Compose environment variables
# Copy to .env and edit before running: cp .env.example .env

# Path to directory containing config.ini (bind-mounted read-only into containers)
GNAT_CONFIG_DIR=./config

# Port bindings (host:container)
EDL_PORT=8080
MONITOR_PORT=8090

# ── Optional: Solr search sidecar (--profile search) ─────────────────────
SOLR_PORT=8983

# ── Optional: Grafana dashboards (--profile monitoring) ──────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=gnat-admin

# Host/port where the GNAT GrafanaServer (gnat viz serve --with-solr) runs.
# On Linux use the host IP; on Mac/Windows host.docker.internal works.
GNAT_GRAFANA_HOST=host.docker.internal
GNAT_VIZ_PORT=3001

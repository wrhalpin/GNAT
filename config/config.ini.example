# GNAT Configuration File
# ===========================
# Place this file at:
#   ~/.gnat/config.ini   (recommended)
#   ./gnat.ini            (project-local)
#   or point GNAT_CONFIG env var to any path
#
# Values in [DEFAULT] are inherited by every target section.

[DEFAULT]
timeout    = 30
verify_ssl = true
max_retries = 3

# =============================================================================
# ThreatQ — OAuth2 client credentials
# =============================================================================
[threatq]
host          = https://threatq.example.com
client_id     = YOUR_CLIENT_ID
client_secret = YOUR_CLIENT_SECRET
auth_type     = oauth2

# =============================================================================
# Proofpoint TAP — HTTP Basic (service principal + secret)
# =============================================================================
[proofpoint]
host               = https://tap-api-v2.proofpoint.com
service_principal  = YOUR_SERVICE_PRINCIPAL
secret             = YOUR_SECRET
auth_type          = basic

# =============================================================================
# Netskope — API token
# =============================================================================
[netskope]
host      = https://YOUR_TENANT.goskope.com
api_token = YOUR_API_TOKEN
auth_type = token

# =============================================================================
# CrowdStrike Falcon — OAuth2 client credentials
# =============================================================================
[crowdstrike]
host          = https://api.crowdstrike.com
client_id     = YOUR_CLIENT_ID
client_secret = YOUR_CLIENT_SECRET
auth_type     = oauth2

# =============================================================================
# XSOAR 6 — API key (+ optional auth_id for MSSP)
# =============================================================================
[xsoar]
host    = https://xsoar.example.com
api_key = YOUR_API_KEY
# auth_id = 1          ; uncomment for MSSP multi-tenant
auth_type = api_key

# =============================================================================
# Recorded Future — API token
# =============================================================================
[recordedfuture]
host      = https://api.recordedfuture.com
api_token = YOUR_RF_API_TOKEN
auth_type = token

# =============================================================================
# ReliaQuest GreyMatter — OAuth2 client credentials
# =============================================================================
[greymatter]
host          = https://api.greymatter.io
client_id     = YOUR_CLIENT_ID
client_secret = YOUR_CLIENT_SECRET
auth_type     = oauth2

# =============================================================================
# Whistic Vendor Security Network — API key
# =============================================================================
[whistic]
host    = https://api.whistic.com
api_key = YOUR_API_KEY
auth_type = api_key

# =============================================================================
# RiskRecon (Mastercard) — OAuth2 client credentials
# =============================================================================
[riskrecon]
host          = https://api.riskrecon.com
client_id     = YOUR_CLIENT_ID
client_secret = YOUR_CLIENT_SECRET
auth_type     = oauth2

# =============================================================================
# Feedly AI / Enterprise — Bearer token (read-only)
# =============================================================================
[feedly]
host      = https://api.feedly.com
api_token = YOUR_ACCESS_TOKEN
auth_type = token

# =============================================================================
# Splunk Enterprise / Cloud — Token (port 8089)
# =============================================================================
[splunk]
host      = https://splunk.example.com:8089
api_token = YOUR_BEARER_TOKEN
# auth_type = basic
# username  = analyst
# password  = your-password
auth_type = token

# =============================================================================
# Claude AI Agent — API key for ResearchAgent and ParsingAgent
# =============================================================================
[claude]
api_key               = sk-ant-YOUR_API_KEY
model                 = claude-sonnet-4-6
max_tokens            = 4096
timeout               = 120
# Maximum confidence assigned to AI-extracted STIX objects (0-100).
# Prevents AI hallucinations propagating to EDLs at high confidence.
ai_confidence_ceiling = 60

# =============================================================================
# Microsoft Copilot — DirectLine secret for CopilotReader
# =============================================================================
[copilot]
# Bot Framework DirectLine secret from Azure Bot registration
# Channels → Direct Line → Secret keys
directline_secret = YOUR_DIRECTLINE_SECRET
# Seconds to wait for Copilot to respond per source query
bot_timeout = 60

# =============================================================================
# Research Library — TTL overrides (hours)
# Defaults: indicator=24, vulnerability=72, campaign=336, threat_actor=720, other=168
# =============================================================================
[research_library]
staging_name     = _ctmsak_staging
library_name     = _ctmsak_library
# Uncomment to override defaults:
# ttl_indicator    = 24
# ttl_vulnerability = 72
# ttl_campaign     = 336
# ttl_threat_actor = 720
# ttl_other        = 168

# =============================================================================
# VirusTotal
# =============================================================================
[virustotal]
host      = https://www.virustotal.com
api_key   = YOUR_VT_API_KEY
auth_type = token

# =============================================================================
# Shadowserver
# =============================================================================
[shadowserver]
host       = https://api.shadowserver.org
api_key    = YOUR_SS_API_KEY
api_secret = YOUR_SS_API_SECRET
auth_type  = token

# =============================================================================
# Rapid7 (InsightVM or Threat Command)
# =============================================================================
[rapid7]
host     = https://us.api.insight.rapid7.com
api_key  = YOUR_R7_API_KEY
product  = insightvm    # or: threat_command
auth_type = token

# =============================================================================
# Nucleus Security
# =============================================================================
[nucleus]
host    = https://api.nucleussec.com
api_key = YOUR_NUCLEUS_API_KEY
project = YOUR_PROJECT_ID
auth_type = token

# =============================================================================
# ControlUp (DEX / VDI & DaaS)
# =============================================================================
[controlup]
host      = https://api.controlup.io
api_key   = YOUR_CONTROLUP_API_KEY
org_id    = YOUR_ORG_ID
product   = dex         # or: vdi
auth_type = token

[servicenow]
host      = https://YOUR_INSTANCE.service-now.com
# Basic auth (username + password):
username  = svc_gnat
password  = YOUR_PASSWORD
# OR bearer token:
# api_key = YOUR_BEARER_TOKEN
# auth_type = api_key

[jira]
host      = https://yourorg.atlassian.net
# Jira Cloud — email + API token (recommended):
email     = user@example.com
api_token = YOUR_API_TOKEN
# OR Jira Server/Data Center — bearer token:
# api_key = YOUR_BEARER_TOKEN
# auth_type = api_key

# =============================================================================
# SMTP — for ReportGenerator email delivery
# =============================================================================
[email]
smtp_host     = smtp.office365.com
smtp_port     = 587
smtp_user     = reports@example.com
smtp_password = YOUR_SMTP_PASSWORD
smtp_tls      = true
from_address  = gnat-reports@example.com

# =============================================================================
# Reports — scheduled report generation
#
# Recommended cron expressions per report type:
#
#   Daily threat intelligence digest  →  schedule = 0 6 * * *
#     (06:00 UTC every day)
#
#   Weekly trends / intelligence brief →  schedule = 0 6 * * 1
#     (06:00 UTC every Monday)
#
#   Annual strategic report            →  schedule = 0 6 1 1 *
#     (06:00 UTC on January 1st — default for report_type = yearly)
#     Using a cron expression rather than a 365-day interval prevents
#     drift when the server restarts mid-year.
#
# All fields follow standard cron syntax:  min hour dom month dow
# =============================================================================
[report:daily-healthcare]
report_type  = daily
workspaces   = _ctmsak_library
sectors      = Healthcare, Opportunistic
formats      = pdf, html, markdown
delivery     = email, file
email_to     = soc-team@example.com
output_dir   = /var/reports/daily
schedule     = 0 6 * * *

[report:weekly-trends]
report_type  = trends
workspaces   = _ctmsak_library
formats      = pdf, html
delivery     = email, file
email_to     = leadership@example.com
output_dir   = /var/reports/weekly
schedule     = 0 6 * * 1

[report:annual]
report_type  = yearly
workspaces   = _ctmsak_library
formats      = pdf, docx
delivery     = email, sharepoint, file
email_to     = ciso@example.com
output_dir   = /var/reports/annual
# schedule defaults to "0 6 1 1 *" when report_type = yearly
# Uncomment to override:
# schedule   = 0 6 1 1 *

# =============================================================================
# ThreatConnect TC Exchange API v3
# =============================================================================
[threatconnect]
host      = https://app.threatconnect.com
# Option 1 — TC-Token (static API token from TC UI):
api_key   = YOUR_TC_API_TOKEN
auth_type = token
# Option 2 — HMAC signing:
# access_id  = YOUR_ACCESS_ID
# secret_key = YOUR_SECRET_KEY
# auth_type  = hmac

# =============================================================================
# Mandiant Advantage Threat Intelligence API
# =============================================================================
[mandiant]
host       = https://api.intelligence.mandiant.com
api_key    = YOUR_MANDIANT_API_KEY
api_secret = YOUR_MANDIANT_API_SECRET
auth_type  = oauth2

# =============================================================================
# Microsoft Defender Threat Intelligence (MS Graph tiIndicators)
# =============================================================================
[defenderti]
host          = https://graph.microsoft.com
tenant_id     = YOUR_AZURE_TENANT_ID
client_id     = YOUR_APP_CLIENT_ID
client_secret = YOUR_APP_CLIENT_SECRET
auth_type     = oauth2

# =============================================================================
# TheHive 5.x SOAR / Case Management
# =============================================================================
[thehive]
host    = https://thehive.example.com
api_key = YOUR_THEHIVE_API_KEY
# org   = MyOrganisation   # optional: multi-tenant X-Organisation header
auth_type = token

# =============================================================================
# Anomali ThreatStream OPTIC API v2
# =============================================================================
[threatstream]
host      = https://api.threatstream.com
username  = your@email.com
api_key   = YOUR_THREATSTREAM_API_KEY
auth_type = api_key

# =============================================================================
# SOCRadar CTI + Attack Surface Management
# =============================================================================
[socradar]
host       = https://platform.socradar.com
api_key    = YOUR_SOCRADAR_API_KEY
# company_id = YOUR_COMPANY_ID   # required for attack-surface endpoints
auth_type  = token

# =============================================================================
# PulseDive Community Threat Intelligence
# =============================================================================
[pulsedive]
host    = https://pulsedive.com
api_key = YOUR_PULSEDIVE_API_KEY
auth_type = token

# =============================================================================
# Flare Systems Threat Exposure Intelligence
# =============================================================================
[flare]
host       = https://api.flare.io
api_key    = YOUR_FLARE_API_KEY
# tenant_id = YOUR_TENANT_ID     # optional: multi-tenant
auth_type  = token

# =============================================================================
# Stellar Cyber Open XDR (Starlight)
# =============================================================================
[stellarcyber]
host      = https://your-tenant.stellarcyber.ai
username  = admin
api_key   = YOUR_STELLARCYBER_API_KEY
auth_type = token

# =============================================================================
# Yeti FOSS Threat Intelligence Platform
# =============================================================================
[yeti]
host    = https://yeti.example.com
api_key = YOUR_YETI_API_KEY
auth_type = token

# =============================================================================
# CloudSEK XVigil Attack Surface Management
# =============================================================================
[cloudsek]
host    = https://api.cloudsek.com
api_key = YOUR_CLOUDSEK_API_KEY
# org_id = YOUR_ORG_ID    # optional: multi-tenant
auth_type = token

# =============================================================================
# Grok/xAI
# =============================================================================
[grok]
host = https://api.x.ai
api_key = xai-...

# =============================================================================
# Google Gemini AI
# =============================================================================
[gemini]
host = https://generativelanguage.googleapis.com
api_key = YOUR_GEMINI_API_KEY

# =============================================================================
# ChatGPT
# =============================================================================
[chatgpt]
host = https://api.openai.com
api_key = <openai-api-key>

# =============================================================================
# MS/ Internal Copilot
# =============================================================================
[copilot]
# Base URL for Microsoft Copilot or an internal Copilot-like LLM
host = https://your-copilot-endpoint

# Authentication mode: "api_key", "azure", or "none"
auth_type = api_key

# API key for internal deployments (used when auth_type = "api_key")
api_key = your-api-key-here

# Azure AD token for Microsoft Copilot (used when auth_type = "azure")
azure_token = your-azure-ad-token-here

# =============================================================================
# Cyble Vision
# =============================================================================
[cyble_vision]
host = https://yourtenant.cyble.ai
api_token = your_token_here

# =============================================================================
# Cortex Xpanse
# =============================================================================
[cortex_xpanse]
host = https://api.xpanse.paloaltonetworks.com
api_key = your_api_key_here
api_key_id = your_api_key_id_here
# =============================================================================
# Cribl Stream
# =============================================================================
[cribl]
host = https://your-cribl-leader.example.com
username = admin
password = your_password_here
# OR use a direct API token instead of username/password:
# token = your_api_token_here
worker_group = default

# =============================================================================
# Synapse (Vertex Project)
# =============================================================================
[synapse]
host = https://your-synapse.example.com
username = root
password = your_password_here
# OR use API key:
# api_key = your_api_key_here
# Default view iden (optional):
# view = <view_iden>

# =============================================================================
# Trellix XDR / ePolicy Orchestrator (ePO)
# =============================================================================
[trellix]
host          = https://api.manage.trellix.com
client_id     = your_client_id_here
client_secret = your_client_secret_here
# Optional: override IAM URL (defaults to https://iam.mcafee-cloud.com)
# iam_url = https://iam.mcafee-cloud.com

# =============================================================================
# Sophos Central
# =============================================================================
[sophos]
host          = https://api.central.sophos.com
client_id     = your_client_id_here
client_secret = your_client_secret_here
# Optional: set tenant ID explicitly (auto-discovered if omitted)
# tenant_id = your_tenant_id_here

# =============================================================================
# Vectra AI NDR
# =============================================================================
[vectra]
host    = https://yourorg.vectra.ai
api_key = your_api_token_here

# =============================================================================
# ExtraHop Reveal(x)
# =============================================================================
[extrahop]
host    = https://your-extrahop-appliance.example.com
api_key = your_api_key_here
# For Reveal(x) 360 cloud, use OAuth2 instead:
# host          = https://company.api.cloud.extrahop.com
# client_id     = your_client_id_here
# client_secret = your_client_secret_here

# =============================================================================
# Darktrace Enterprise Immune System
# =============================================================================
[darktrace]
host        = https://your-darktrace-instance.example.com
public_key  = your_public_key_here
private_key = your_private_key_here

# =============================================================================
# Lansweeper IT Asset Management
# =============================================================================
[lansweeper]
host          = https://api.lansweeper.com
client_id     = your_application_client_id_here
client_secret = your_application_client_secret_here
site_id       = your_lansweeper_site_id_here
# Alternative: use personal access token
# api_key = your_personal_access_token_here

# =============================================================================
# Censys Internet Intelligence / ASM
# =============================================================================
[censys]
host       = https://search.censys.io
api_id     = your_api_id_here
api_secret = your_api_secret_here

# =============================================================================
# ServiceNow SecOps (SIR + Vulnerability Response + TIARA)
# =============================================================================
[servicenow_secops]
host     = https://instance.service-now.com
username = admin
password = your_password_here
# OR use Bearer token:
# api_key = your_bearer_token_here

# =============================================================================
# BitSight Security Ratings & Vendor Risk Management
# =============================================================================
[bitsight]
host  = https://api.bitsighttech.com
token = your_bitsight_api_token_here

# =============================================================================
# Flashpoint Underground / Dark Web CTI
# =============================================================================
[flashpoint]
host  = https://api.flashpoint.io
token = your_flashpoint_api_token_here

# =============================================================================
# Hudson Rock Breach Intelligence & Credential Exposure
# =============================================================================
[hudsonrock]
host    = https://api.hudsonrock.com
api_key = your_hudsonrock_api_key_here

# =============================================================================
# Intel 471 Cybercrime-Focused Threat Intelligence
# =============================================================================
[intel471]
host  = https://api.intel471.com
token = your_intel471_api_token_here

# =============================================================================
# UpGuard Vendor Risk + CAASM + Digital Risk Protection
# =============================================================================
[upguard]
host    = https://cyber-risk.upguard.com
api_key = your_upguard_api_key_here

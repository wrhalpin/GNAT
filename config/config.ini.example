api_key    = YOUR_SOCRADAR_API_KEY
# company_id = YOUR_COMPANY_ID   # required for attack-surface endpoints
auth_type  = token

# =============================================================================
# PulseDive Community Threat Intelligence
# =============================================================================
[pulsedive]
host    = https://pulsedive.com
api_key = YOUR_PULSEDIVE_API_KEY
auth_type = token

# =============================================================================

# EU customers: host = https://api.datadoghq.eu
# =============================================================================
# LLM Agents config
# =============================================================================
[llm]
default_backend = claude          # claude | openai | grok | gemini | hybrid
ai_confidence_ceiling = 70

# Claude (existing)
[claude]
api_key = ...
model = claude-sonnet-4-6        # or latest

# OpenAI
[openai]
api_key = ...
model = gpt-4o-mini              # or gpt-4o, o1-mini, etc.
base_url = https://api.openai.com/v1   # for Azure or local proxies

# Grok / xAI
[grok]
api_key = ...
model = grok-4                   # or grok-beta, etc.
host = https://api.x.ai

# Gemini
[gemini]
api_key = ...
model = gemini-2.5-flash         # or gemini-2.5-pro

# =============================================================================
# MS/ Internal Copilot
# =============================================================================
[copilot]
# Base URL for Microsoft Copilot or an internal Copilot-like LLM
host = https://your-copilot-endpoint

# Authentication mode: "api_key", "azure", or "none"
auth_type = api_key

# API key for internal deployments (used when auth_type = "api_key")
api_key = your-api-key-here

# Azure AD token for Microsoft Copilot (used when auth_type = "azure")
azure_token = your-azure-ad-token-here

# =============================================================================
# Palo Alto Networks Cortex XDR / XSIAM
# =============================================================================
[cortex_xdr]
host        = https://api-<tenant>.xdr.us.paloaltonetworks.com
api_key_id  = 1
api_key     = your_cortex_xdr_api_key_here
auth_type   = api_key

# =============================================================================
# Palo Alto Networks Prisma Cloud
# =============================================================================
[prisma_cloud]
host           = https://api.prismacloud.io
access_key_id  = your_prisma_access_key_id_here
secret_key     = your_prisma_secret_key_here
auth_type      = api_key
# For EU/APAC tenants change host to api.eu.prismacloud.io / api.sg.prismacloud.io

